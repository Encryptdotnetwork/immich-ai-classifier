# Copy to .env and fill in. Loaded ONCE at startup (app/config.py).
# ---------------------------------------------------------------------------

# --- Immich connection ---
# Base URL of the Immich server, WITHOUT a trailing /api (the client appends it).
# This container joins Immich's network (see docker-compose.yml), so it reaches
# the API container-to-container by name. immich_server is the container_name in
# the Immich compose; 2283 is the internal port.
# Fallback if you don't share a network: use the host IP, e.g. http://<host>:2283
IMMICH_URL=http://immich_server:2283
IMMICH_API_KEY=replace-with-immich-api-key

# --- Path translation (see app/paths.py) ---
# IMMICH_INTERNAL_PREFIX: the prefix the Immich *server* container uses for its
# library internally. Common default is /usr/src/app/upload, but VERIFY IT:
# run the acceptance test and read the raw originalPath it prints, then set this
# to whatever leading directory that path actually has. Storage template is off
# by default, so expect a UUID path like:
#   /usr/src/app/upload/upload/<userId>/ab/cd/<uuid>.jpg
IMMICH_INTERNAL_PREFIX=/usr/src/app/upload

# LOCAL_MOUNT: where the same library is bind-mounted (read-only) in THIS
# container. Must equal the mount target in docker-compose.yml.
LOCAL_MOUNT=/immich-library

# IMMICH_LIBRARY_HOST_PATH: the directory ON THE DOCKER HOST that gets
# bind-mounted read-only to LOCAL_MOUNT. This is the Immich UPLOAD_LOCATION on
# disk — the same dir Immich mounts to /usr/src/app/upload. It typically
# contains library/ upload/ thumbs/ profile/ encoded-video/ backups/.
IMMICH_LIBRARY_HOST_PATH=/path/to/immich/library

# --- Asset under test (acceptance test) ---
# Known asset id to run the verify / acceptance test against. Optional: can be
# passed as a CLI arg instead (python -m app.main <asset_id>).
ASSET_ID=

# --- Inference roles (OpenAI-compatible chat completions) ---
# Backend may be local (Ollama on a LAN GPU) or remote. The code does not care
# which. Set VISION_* to enable `--classify`.
#
# VISION_ENDPOINT: base URL ending in /v1 (the client appends /chat/completions),
# or a full .../chat/completions URL. Examples:
#   local Ollama on the LAN:  http://192.168.x.x:11434/v1
#   remote provider:          https://api.your-provider.com/v1
# VISION_MODEL: a vision-capable model id (e.g. qwen2.5vl, llava, a hosted VLM).
# VISION_KEY: leave blank for local servers with no auth.
VISION_ENDPOINT=
VISION_MODEL=
VISION_KEY=
# TEXT_* role is still a placeholder (unused until the text/transcript stage).
TEXT_ENDPOINT=
TEXT_MODEL=
TEXT_KEY=

# --- Write-back tag verify-and-retry (Stage 3) ---
# Immich returns 200 before a tag persists and can silently tag only some
# assets, so we re-read and retry. Defaults: 3 retries, 1.5s before each re-read.
TAG_VERIFY_MAX_RETRIES=3
TAG_VERIFY_DELAY=1.5

# --- Batch processing (Stage 4) ---
# Album to enumerate (paginated via search/metadata, never the 1000-capped
# GET /api/albums/{id}). Set this to YOUR source album — the album that holds the
# unsorted items you want classified. The default below is just a placeholder.
SOURCE_ALBUM=Unsorted
# Writable dir for the SQLite cache. Container path; compose maps it to the host
# dir APP_DATA_HOST_PATH via the /data mount.
APP_DATA_DIR=/data
# Host dir for the SQLite cache / app data. Set to your own path.
APP_DATA_HOST_PATH=/opt/appdata/immich-ai-classifier
# Assets per tag/verify group (amortises the 1.5s verify delay across the group).
BATCH_GROUP_SIZE=25
# Optional pause (seconds) between inference calls, to be gentle on the endpoints.
BATCH_PAUSE=0.0

# --- Category taxonomy (Stage 6) ---
# The categories, the review machinery (confidence threshold, _Review album,
# needs-review tag), the marker tag, and source detection now live in a
# user-editable YAML — NOT in env or code. Edit config/categories.yaml to change
# them; the app validates it at startup and refuses to run on a bad config.
# (REVIEW_ALBUM / REVIEW_THRESHOLD were removed from here — they moved into that
# file as review.album_name / review.threshold.)
# CATEGORIES_FILE optionally overrides the path to that YAML. Leave blank to use
# the shipped config/categories.yaml (mounted to /app/config/categories.yaml).
CATEGORIES_FILE=
